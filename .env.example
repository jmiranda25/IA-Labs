# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT Secrets (generate with: openssl rand -hex 32) ────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-replace-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-replace-this

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
FRONTEND_URL=https://your-frontend-domain.com

# ── Bootstrap admins (comma-separated emails) ─────────────────────────────────
# These accounts are automatically activated and granted administrator role.
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
BOOTSTRAP_DONE=false

# ── Object Storage (optional) ─────────────────────────────────────────────────
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
# PRIVATE_OBJECT_DIR=private
# PUBLIC_OBJECT_SEARCH_PATHS=public
